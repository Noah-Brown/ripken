{$SITE_ADDRESS:localhost} {
    handle /api/auth/* {
        reverse_proxy frontend:3000
    }
    handle /api/* {
        reverse_proxy backend:8000
    }
    handle /auth/* {
        reverse_proxy backend:8000
    }
    handle /health {
        reverse_proxy backend:8000
    }
    handle {
        reverse_proxy frontend:3000
    }
}
